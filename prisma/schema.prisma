generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Arcana {
  major
  minor
}

enum Suit {
  wands
  cups
  swords
  pentacles
}

model TarotCard {
  id           String    @id
  nameEn       String
  nameTh       String?
  arcana       Arcana
  suit         Suit?
  number       Int?
  rank         String?
  imageUrl     String?
  backImageUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  meaning      TarotCardMeaning?
  readingCards ReadingCard[]

  @@index([arcana])
  @@index([suit])
}

model TarotCardMeaning {
  id                  String   @id @default(cuid())
  cardId              String   @unique
  coreMeaning         String?  @db.Text
  symbols             String?  @db.Text
  keywords            String[]
  generalSituation    String?  @db.Text
  personality         String?  @db.Text
  work                String?  @db.Text
  study               String?  @db.Text
  finance             String?  @db.Text
  loveAndRelationship String?  @db.Text
  singleLove          String?  @db.Text
  health              String?  @db.Text
  timingSpeed         String?
  timingPeriod        String?
  timingNote          String?  @db.Text
  summary             String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  card TarotCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model ReadingSession {
  id               String    @id @default(cuid())
  readingType      String
  category         String?
  questionText     String?   @db.Text
  mode             String    @default("test")
  algorithmVersion String
  promptVersion    String?
  aiModel          String?
  status           String    @default("created")
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  cards  ReadingCard[]
  output ReadingOutput?
  review InternalReadingReview?

  @@index([readingType])
  @@index([status])
  @@index([category])
}

model ReadingCard {
  id                     String   @id @default(cuid())
  readingSessionId       String
  cardId                 String
  positionIndex          Int
  positionKey            String
  positionLabel          String
  meaningSnapshot        Json
  keywordsSnapshot       String[]
  interpretationSnapshot String?  @db.Text
  createdAt              DateTime @default(now())

  readingSession ReadingSession @relation(fields: [readingSessionId], references: [id], onDelete: Cascade)
  card           TarotCard      @relation(fields: [cardId], references: [id])

  @@index([readingSessionId])
  @@index([cardId])
}

model ReadingOutput {
  id                String   @id @default(cuid())
  readingSessionId  String   @unique
  structuredOutline Json
  algorithmText     String?  @db.Text
  aiPrompt          Json?
  aiOutput          String?  @db.Text
  finalOutput       String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  readingSession ReadingSession @relation(fields: [readingSessionId], references: [id], onDelete: Cascade)
}

model InternalReadingReview {
  id               String    @id @default(cuid())
  readingSessionId String    @unique
  ratingOverall    Int?
  ratingAccuracy   Int?
  ratingTone       Int?
  ratingUsefulness Int?
  isApproved       Boolean   @default(false)
  reviewStatus     String    @default("pending")
  reviewNote       String?   @db.Text
  suggestedFix     String?   @db.Text
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  readingSession ReadingSession @relation(fields: [readingSessionId], references: [id], onDelete: Cascade)

  @@index([reviewStatus])
  @@index([isApproved])
}
